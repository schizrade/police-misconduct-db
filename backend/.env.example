# Database Configuration
DATABASE_URL=postgresql://misconduct_user:change_this_password@localhost:5432/misconduct_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# Security — generate with: openssl rand -hex 32
SECRET_KEY=generate_a_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated, add your server IP / domain)
ALLOWED_ORIGINS=http://localhost:3000,http://your-server-ip:3000

# Application
APP_NAME=Police Misconduct Database
VERSION=2.0.0
